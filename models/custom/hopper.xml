<mujoco model="hopper">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true" />
    <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4" />

    <default>
        <joint armature="1" damping="1" limited="true"/>
        <geom conaffinity="1" condim="3" density="5.0" friction="1 0.5 0.5" margin="0.01" rgba="0.8 0.6 0.4 1"/>
        <motor ctrllimited="true" ctrlrange="-1.0 1.0"/>
    </default>

    <asset>
        <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
        <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
    </asset>

    <worldbody>
        <!-- Ground Plane -->
        <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
        <geom conaffinity="1" condim="3" material="MatPlane" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane"/>

        <!-- Hopper Body -->
        <body name="torso" pos="0 0 1.25">
            <camera name="track" mode="trackcom" pos="0 -3 0.3" xyaxes="1 0 0 0 0 1"/>
            <joint armature="0" damping="0" limited="false" margin="0.01" name="root" pos="0 0 0" type="free"/>
            <geom pos="0 0 0" size="0.05 0.2" type="cylinder" rgba="0.9 0.2 0.2 1" />
            
            <!-- Thigh -->
            <body name="thigh" pos="0 0 -0.2">
                <joint axis="0 1 0" name="thigh_joint" pos="0 0 0" range="-150 0" type="hinge"/>
                <geom fromto="0 0 0 0 0 -0.4" name="thigh_geom" size="0.05" type="capsule" rgba="0.2 0.8 0.2 1" />
                
                <!-- Leg -->
                <body name="leg" pos="0 0 -0.4">
                    <joint axis="0 1 0" name="leg_joint" pos="0 0 0" range="-150 0" type="hinge"/>
                    <geom fromto="0 0 0 0 0 -0.5" name="leg_geom" size="0.04" type="capsule" rgba="0.2 0.2 0.9 1" />
                    
                    <!-- Foot -->
                    <body name="foot" pos="0 0 -0.5">
                        <joint axis="0 1 0" name="foot_joint" pos="0 0 0" range="-45 45" type="hinge"/>
                        <geom fromto="-0.1 0 0 0.2 0 0" name="foot_geom" size="0.06" type="capsule" rgba="0.9 0.9 0.2 1" />
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- Actuators (Motors) attached to the joints -->
    <actuator>
        <motor gear="200.0" joint="thigh_joint" name="thigh_motor"/>
        <motor gear="200.0" joint="leg_joint" name="leg_motor"/>
        <motor gear="100.0" joint="foot_joint" name="foot_motor"/>
    </actuator>
</mujoco>
