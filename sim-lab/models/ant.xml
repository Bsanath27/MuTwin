<mujoco model="ant_simple">
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid"/>

    <body name="torso" pos="0 0 0.75">
      <freejoint name="root"/>
      <geom name="torso_geom" type="sphere" size="0.25"
            rgba="0.8 0.6 0.1 1" mass="10"/>

      <body name="front_left_leg" pos="0.2 0.2 0">
        <joint name="hip_fl" type="hinge" axis="0 0 1" limited="true"
               range="-30 30" damping="1"/>
        <geom name="fl_upper" type="capsule" fromto="0 0 0 0.2 0.2 0"
              size="0.08" rgba="0.3 0.5 0.3 1" mass="1"/>
        <body name="front_left_foot" pos="0.2 0.2 0">
          <joint name="ankle_fl" type="hinge" axis="-1 1 0" limited="true"
                 range="30 70" damping="1"/>
          <geom name="fl_lower" type="capsule" fromto="0 0 0 0.2 0.2 -0.4"
                size="0.08" rgba="0.3 0.3 0.3 1" mass="1"/>
        </body>
      </body>

      <body name="front_right_leg" pos="-0.2 0.2 0">
        <joint name="hip_fr" type="hinge" axis="0 0 1" limited="true"
               range="-30 30" damping="1"/>
        <geom name="fr_upper" type="capsule" fromto="0 0 0 -0.2 0.2 0"
              size="0.08" rgba="0.3 0.5 0.3 1" mass="1"/>
        <body name="front_right_foot" pos="-0.2 0.2 0">
          <joint name="ankle_fr" type="hinge" axis="1 1 0" limited="true"
                 range="-70 -30" damping="1"/>
          <geom name="fr_lower" type="capsule" fromto="0 0 0 -0.2 0.2 -0.4"
                size="0.08" rgba="0.3 0.3 0.3 1" mass="1"/>
        </body>
      </body>

      <body name="back_left_leg" pos="-0.2 -0.2 0">
        <joint name="hip_bl" type="hinge" axis="0 0 1" limited="true"
               range="-30 30" damping="1"/>
        <geom name="bl_upper" type="capsule" fromto="0 0 0 -0.2 -0.2 0"
              size="0.08" rgba="0.3 0.5 0.3 1" mass="1"/>
        <body name="back_left_foot" pos="-0.2 -0.2 0">
          <joint name="ankle_bl" type="hinge" axis="1 1 0" limited="true"
                 range="-70 -30" damping="1"/>
          <geom name="bl_lower" type="capsule" fromto="0 0 0 -0.2 -0.2 -0.4"
                size="0.08" rgba="0.3 0.3 0.3 1" mass="1"/>
        </body>
      </body>

      <body name="back_right_leg" pos="0.2 -0.2 0">
        <joint name="hip_br" type="hinge" axis="0 0 1" limited="true"
               range="-30 30" damping="1"/>
        <geom name="br_upper" type="capsule" fromto="0 0 0 0.2 -0.2 0"
              size="0.08" rgba="0.3 0.5 0.3 1" mass="1"/>
        <body name="back_right_foot" pos="0.2 -0.2 0">
          <joint name="ankle_br" type="hinge" axis="-1 1 0" limited="true"
                 range="30 70" damping="1"/>
          <geom name="br_lower" type="capsule" fromto="0 0 0 0.2 -0.2 -0.4"
                size="0.08" rgba="0.3 0.3 0.3 1" mass="1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="hip_fl_motor" joint="hip_fl" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="ankle_fl_motor" joint="ankle_fl" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="hip_fr_motor" joint="hip_fr" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="ankle_fr_motor" joint="ankle_fr" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="hip_bl_motor" joint="hip_bl" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="ankle_bl_motor" joint="ankle_bl" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="hip_br_motor" joint="hip_br" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
    <motor name="ankle_br_motor" joint="ankle_br" ctrllimited="true" ctrlrange="-1 1" gear="150"/>
  </actuator>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.1 0.1 0.2"
             rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
             rgb2=".2 .3 .4" width="512" height="512" mark="edge"
             markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1"
              texuniform="true" reflectance=".2"/>
  </asset>
</mujoco>
