<mujoco model="floating_box">
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="5 5 0.05" material="grid"/>

    <body name="box" pos="0 0 2">
      <freejoint name="free"/>
      <geom name="box_geom" type="box" size="0.3 0.3 0.3"
            rgba="0.2 0.8 0.6 1" mass="2"/>
    </body>

    <body name="sphere" pos="1 0 3">
      <freejoint name="free2"/>
      <geom name="sphere_geom" type="sphere" size="0.2"
            rgba="0.8 0.2 0.4 1" mass="1"/>
    </body>

    <body name="capsule" pos="-1 0 2.5">
      <freejoint name="free3"/>
      <geom name="capsule_geom" type="capsule" size="0.1 0.3"
            rgba="0.3 0.4 0.9 1" mass="1.5"/>
    </body>
  </worldbody>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.1 0.1 0.2"
             rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
             rgb2=".2 .3 .4" width="512" height="512" mark="edge"
             markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1"
              texuniform="true" reflectance=".2"/>
  </asset>
</mujoco>
