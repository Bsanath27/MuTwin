<mujoco model="ant_simple">
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global offwidth="1024" offheight="1024"/>
  </visual>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid"/>
    
    <body name="torso" pos="0 0 1">
      <freejoint/>
      <geom name="torso_geom" type="sphere" size="0.25" rgba="0.8 0.8 0.1 1" mass="10"/>
      <body name="leg1" pos="0.2 0.2 0">
         <geom name="leg1_geom" type="capsule" size="0.08 0.5" rgba="0.3 0.3 0.3 1" mass="2" euler="0 45 0"/>
      </body>
      <body name="leg2" pos="-0.2 0.2 0">
         <geom name="leg2_geom" type="capsule" size="0.08 0.5" rgba="0.3 0.3 0.3 1" mass="2" euler="0 -45 0"/>
      </body>
      <body name="leg3" pos="-0.2 -0.2 0">
         <geom name="leg3_geom" type="capsule" size="0.08 0.5" rgba="0.3 0.3 0.3 1" mass="2" euler="0 -135 0"/>
      </body>
      <body name="leg4" pos="0.2 -0.2 0">
         <geom name="leg4_geom" type="capsule" size="0.08 0.5" rgba="0.3 0.3 0.3 1" mass="2" euler="0 135 0"/>
      </body>
    </body>
  </worldbody>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.1 0.1 0.2" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="512" height="512" mark="edge" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>
</mujoco>
